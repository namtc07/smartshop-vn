datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    String          @id @default(uuid())
  email                 String          @unique
  password              String
  bioPageSlug           String          @unique
  displayName           String?
  bio                   String?
  avatarUrl             String?
  socialLinks           Json?
  themeSettings         Json?
  seoTitle              String?
  seoDescription        String?
  ogImage               String?
  defaultConversionRate Float?
  defaultCommissionRate Float?
  ShortLinks            ShortLink[]
  Categories            Category[]
  RevenueEntries        RevenueEntry[]
}

model Product {
  id           String      @id @default(uuid())
  platform     String
  originalUrl  String
  name         String
  imageUrl     String?
  currentPrice Float?
  ShortLinks   ShortLink[]
}

model Category {
  id         String      @id @default(uuid())
  userId     String
  name       String
  sortOrder  Int         @default(0)
  User       User        @relation(fields: [userId], references: [id])
  ShortLinks ShortLink[]
}

model ShortLink {
  id                String          @id @default(uuid())
  userId            String
  productId         String
  shortCode         String          @unique
  affiliateDeepLink String
  isActiveOnBio     Boolean         @default(true)
  sortOrder         Int             @default(0)
  isFeatured        Boolean         @default(false)
  badgeText         String?
  videoUrl          String?
  customShortCode   String?         @unique
  commissionRate    Float?
  conversionRate    Float?
  categoryId        String?
  startDate         DateTime?
  endDate           DateTime?
  User              User            @relation(fields: [userId], references: [id])
  Product           Product         @relation(fields: [productId], references: [id])
  Category          Category?       @relation(fields: [categoryId], references: [id])
  ClickTrackings    ClickTracking[]
}

model RevenueEntry {
  id           String   @id @default(uuid())
  userId       String
  month        String
  platform     String
  actualAmount Float
  notes        String?
  createdAt    DateTime @default(now())
  User         User     @relation(fields: [userId], references: [id])
}

model ClickTracking {
  id          String    @id @default(uuid())
  shortLinkId String
  clickedAt   DateTime  @default(now())
  deviceOS    String?
  referrer    String?
  ShortLink   ShortLink @relation(fields: [shortLinkId], references: [id])
}
