datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  bioPageSlug String      @unique
  ShortLinks  ShortLink[]
}

model Product {
  id          String      @id @default(uuid())
  platform    String
  originalUrl String
  name        String
  imageUrl    String?
  currentPrice Float?
  ShortLinks  ShortLink[]
}

model ShortLink {
  id                String          @id @default(uuid())
  userId            String
  productId         String
  shortCode         String          @unique
  affiliateDeepLink String
  isActiveOnBio     Boolean         @default(true)
  User              User            @relation(fields: [userId], references: [id])
  Product           Product         @relation(fields: [productId], references: [id])
  ClickTrackings    ClickTracking[]
}

model ClickTracking {
  id          String      @id @default(uuid())
  shortLinkId String
  clickedAt   DateTime    @default(now())
  deviceOS    String?
  referrer    String?
  ShortLink   ShortLink   @relation(fields: [shortLinkId], references: [id])
}
